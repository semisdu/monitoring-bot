# Monitoring Bot Configuration Example
# Copy to config.yml and fill with your data

telegram:
  token: "YOUR_BOT_TOKEN_HERE"  # Get from @BotFather
  admin_chat_id: 123456789       # Your Telegram ID

paths:
  base_dir: "/opt/monitoring-bot"
  logs: "logs"
  database: "database"
  ssh_keys: "~/.ssh"  # Directory where SSH keys are stored (can be empty)

# ==================== СЕРВЕРЫ ====================
servers:
  # Example server with Docker
  - id: "example-server"
    name: "Example Server"
    host: "192.168.1.100"
    user: "username"        # SSH user on the server
    port: 22
    ssh_key: "id_ed25519"   # Only filename, bot will find it in ~/.ssh/
    docker_enabled: true
    containers:
      - name: "postgres"
        service_name: "postgres"
        critical: true
      - name: "app"
        service_name: "web"
        critical: true

  # Example PVE server
  - id: "pve-example"
    name: "PVE Hypervisor"
    host: "192.168.1.99"
    user: "username"
    port: 22
    ssh_key: "id_ed25519"
    type: "pve"
    api_enabled: true
    api_host: "192.168.1.99"
    api_port: 8006
    api_user: "root@pam"
    api_verify_ssl: false
    vms: [100, 101]

  # Example PBS server
  - id: "pbs-example"
    name: "Backup Server"
    host: "192.168.1.37"
    user: "root"
    port: 22
    ssh_key: "id_ed25519"
    type: "pbs"
    api_enabled: true
    api_host: "192.168.1.37"
    api_port: 8007
    api_user: "root@pbs"
    api_verify_ssl: false
    datastore: "local"

# ==================== САЙТЫ ====================
sites:
  - name: "Example Site"
    url: "https://example.com"
    server_id: "example-server"
    check_interval: 300
    critical: true
    expected_status: 200
    timeout: 10

  - name: "External Site"
    url: "http://example.org"
    type: "external"
    check_interval: 300
    critical: true
    expected_status: 200
    timeout: 10

# ==================== ВИРТУАЛЬНЫЕ МАШИНЫ ====================
virtual_machines:
  - id: "vm100-example"
    name: "Example VM"
    vmid: 100
    server_id: "pve-example"
    description: "Example virtual machine"
    critical: true
    monitoring:
      status: true
      resources: true
      alerts: true

# ==================== БЭКАПЫ ====================
backup_jobs:
  - id: "pbs-daily-backup"
    name: "Daily VM Backups"
    server_id: "pbs-example"
    check_type: "backup_status"
    schedule: "daily"
    retention_days: 7
    vms: [100, 101]

# ==================== МОНИТОРИНГ ЛОГОВ ====================
log_monitoring:
  enabled: false
  check_interval: 300
  alert_cooldown: 3600
  daily_reminder: "09:00"
  critical_patterns:
    - '5\d\d'
    - 'HTTP/1\.1" 50'
    - 'HTTP/1\.1" 40[34]'
    - 'CRITICAL'
    - 'ERROR'
    - 'Exception'
    - 'Traceback'
    - '\[emerg\]'
    - '\[alert\]'
    - '\[crit\]'
  log_paths:
    example-server:
      - "/var/log/nginx/access.log"
      - "/var/log/nginx/error.log"

# ==================== РАСПИСАНИЕ ====================
schedule:
  status_check: "*/5 * * * *"
  log_check: "*/5 * * * *"
  daily_report: "0 9 * * *"
  cleanup: "0 2 * * 1"
  vm_check: "0 */1 * * *"
  backup_check: "0 6 * * *"
  docker_check: "*/10 * * * *"
  site_check: "*/15 * * * *"

# ==================== НАСТРОЙКИ АЛЕРТОВ ====================
alert_config:
  disk_warning_percent: 80
  disk_critical_percent: 90
  memory_warning_percent: 85
  memory_critical_percent: 95
  cpu_warning_percent: 80
  cpu_critical_percent: 90
  site_timeout_seconds: 10
  container_restart_threshold: 3
  error_count_threshold: 10
  vm_cpu_threshold: 80
  vm_memory_threshold: 85
  backup_age_warning_hours: 48
  backup_age_critical_hours: 72

# ==================== НАСТРОЙКИ ЛОГИРОВАНИЯ ====================
logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  max_size_mb: 10
  backup_count: 5

# ==================== ФУНКЦИОНАЛ ====================
features:
  enable_infra_commands: true
  enable_log_monitoring: false
  enable_auto_restart: false
  enable_daily_reports: true
  enable_backup: true
  enable_proxmox: true
  enable_vm_monitoring: true
  enable_backup_check: true
  enable_docker: true
  enable_site_check: true

# ==================== НАСТРОЙКИ АНАЛИТИКИ ====================
analytics:
  enabled: true
  error_tracking:
    enabled: true
    group_similar: true
    similar_threshold: 0.8
    store_history_days: 30
  trends:
    enabled: true
    period_days: 7
  recommendations:
    enabled: true
    auto_fix: false

# ==================== НАСТРОЙКИ УВЕДОМЛЕНИЙ ====================
notifications:
  language: "ru"
  instant_alerts:
    enabled: true
    cooldown_minutes: 30
    group_during_cooldown: true
    channels:
      - telegram
    critical_only: false
  daily_report:
    enabled: true
    time: "09:00"
    timezone: "Europe/Kiev"
    format: "detailed"
    channels:
      - telegram
    sections:
      - summary: true
      - new_errors: true
      - recurring: true
      - recommendations: true
      - trends: true
    include:
      - sites
      - docker
      - pve
      - pbs
      - system

# ==================== НАСТРОЙКИ SSH ====================
ssh:
  connection_timeout: 10
  command_timeout: 30
  max_connections: 5
  retry_attempts: 2
