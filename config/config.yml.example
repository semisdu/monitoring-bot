# Monitoring Bot Configuration Example
# Скопируйте в config.yml и заполните своими данными

# ==================== TELEGRAM ====================
telegram:
  token: "YOUR_BOT_TOKEN_HERE"  # Получить у @BotFather
  admin_chat_id: YOUR_TELEGRAM_ID  # Ваш ID (можно узнать у @userinfobot)

# ==================== ПУТИ ====================
paths:
  base_dir: "/opt/monitoring-bot"
  logs: "logs"
  database: "database"
  ssh_keys: "/opt/monitoring-bot/keys"

# ==================== СЕРВЕРЫ ====================
servers:
  # Пример сервера с Docker
  - id: "example-server"
    name: "Example Server"
    host: "192.168.1.100"
    user: "username"
    port: 22
    ssh_key: "YOUR_KEY_NAME"
    docker_enabled: true
    containers:
      - name: "postgres"
        service_name: "postgres"
        critical: true
        log_type: "postgres"
      - name: "app"
        service_name: "web"
        critical: true
        log_type: "django_app"

  # Пример PVE сервера
  - id: "pve-example"
    name: "PVE Hypervisor"
    host: "192.168.1.99"
    user: "root"
    ssh_key: "YOUR_KEY_NAME"
    type: "pve"
    api_enabled: true
    api_host: "192.168.1.99"
    api_port: 8006
    api_user: "root@pam"
    api_verify_ssl: false
    vms: [100, 101]

  # Пример PBS сервера
  - id: "pbs-example"
    name: "Backup Server"
    host: "192.168.1.37"
    user: "root"
    ssh_key: "YOUR_KEY_NAME"
    type: "pbs"
    api_enabled: true
    api_host: "192.168.1.37"
    api_port: 8007
    api_user: "root@pbs"
    api_verify_ssl: false
    datastore: "local"

# ==================== САЙТЫ ====================
sites:
  - name: "Example Site"
    url: "https://example.com"
    server_id: "example-server"
    check_interval: 300
    critical: true
    expected_status: 200
    timeout: 10

# ==================== ВИРТУАЛЬНЫЕ МАШИНЫ ====================
virtual_machines:
  - id: "vm100-example"
    name: "Example VM"
    vmid: 100
    server_id: "pve-example"
    critical: true
    monitoring:
      status: true
      resources: true
      alerts: true

# ==================== БЭКАПЫ ====================
backup_jobs:
  - id: "daily-backup"
    name: "Daily VM Backups"
    server_id: "pbs-example"
    check_type: "backup_status"
    schedule: "daily"
    retention_days: 7
    vms: [100, 101]

# ==================== МОНИТОРИНГ ЛОГОВ КОНТЕЙНЕРОВ ====================
container_log_monitoring:
  enabled: true
  check_interval: 300
  alert_cooldown: 1800
  default_log_lines: 200
  
  patterns:
    django_app:
      name: "Django App"
      patterns:
        - ["OperationalError", "Ошибка БД: {0}"]
        - ["Internal Server Error", "500 ошибка: {0}"]
        - ["ERROR", "Ошибка: {0}"]
    postgres:
      name: "PostgreSQL"
      patterns:
        - ["FATAL", "Фатальная ошибка: {0}"]
        - ["ERROR", "Ошибка БД: {0}"]
    nginx:
      name: "Nginx"
      patterns:
        - ["[error]", "Ошибка: {0}"]
        - ["[emerg]", "Критическая ошибка: {0}"]

# ==================== РАСПИСАНИЕ ====================
schedule:
  status_check: "*/5 * * * *"
  docker_check: "*/10 * * * *"
  daily_report: "0 8 * * *"
  cleanup: "0 2 * * 1"
  vm_check: "0 */1 * * *"
  backup_check: "0 6 * * *"
  site_check: "*/15 * * * *"

# ==================== УВЕДОМЛЕНИЯ И ОТЧЁТЫ ====================
notifications:
  daily_report:
    enabled: true
    time: "08:00"  # Время отправки ежедневного отчёта

# ==================== АЛЕРТЫ ====================
alert_config:
  disk_warning_percent: 80
  disk_critical_percent: 90
  memory_warning_percent: 85
  memory_critical_percent: 95
  cpu_warning_percent: 80
  cpu_critical_percent: 90
  site_timeout_seconds: 10
  container_restart_threshold: 3
  backup_age_warning_hours: 48
  backup_age_critical_hours: 72

# ==================== ЛОГИРОВАНИЕ ====================
logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  max_size_mb: 10
  backup_count: 5

# ==================== ФУНКЦИОНАЛ ====================
features:
  enable_infra_commands: true
  enable_log_monitoring: true   # ВАЖНО: true для работы планировщика!
  enable_auto_restart: false
  enable_daily_reports: true
  enable_backup: true
  enable_proxmox: true
  enable_vm_monitoring: true
  enable_backup_check: true
  enable_docker: true
  enable_site_check: true
  enable_cleanup: true
