async def menu_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /menu"""
    await start_command(update, context)

# ==================== КОМАНДЫ СТАТУСА ====================

async def status301_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /status301"""
    user_id = get_user_id(update)
    
    # Отправляем сообщение о начале проверки
    message = await update.message.reply_text(
        f"{get_text(user_id, 'status', 'checking_301')}... ⏳"
    )
    
    try:
        from checks.servers import get_server_checker
        checker = get_server_checker()
        status = checker.check_remote_server("serv301")
        
        # Форматируем результат
        status_text = format_server_status(status, user_id)
        
        # Обновляем сообщение с результатом
        await message.edit_text(status_text, parse_mode='Markdown')
        
        logger.info(f"Пользователь {user_id} запросил статус SERV301")
        
    except Exception as e:
        logger.error(f"Ошибка при проверке SERV301: {e}")
        await message.edit_text(
            f"❌ {get_text(user_id, 'common', 'error')}: {str(e)}"
        )

