async def check_all_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /status или /check_all"""
    user_id = get_user_id(update)
    
    # Отправляем сообщение о начале проверки
    message = await update.message.reply_text(
        f"{get_text(user_id, 'status', 'checking_all')}... ⏳"
    )
    
    try:
        from checks.servers import get_server_checker
        checker = get_server_checker()
        
        # Проверяем все серверы
        servers_to_check = ["serv301", "serv300", "server102"]
        results = []
        
        for server in servers_to_check:
            status = checker.check_remote_server(server)
            results.append((server, status))
        
        # Форматируем общий результат
        result_text = f"🔍 **{get_text(user_id, 'status', 'checking_all')}**\n\n"
        
        for server_name, status in results:
            server_display = {
                "serv301": "SERV301 🖥",
                "serv300": "SERV300 🖥", 
                "server102": "SERVER102 🌐"
            }.get(server_name, server_name)
            
            if status.get('status') == 'online':
                result_text += f"✅ {server_display}: 🟢 Online\n"
                
                # Добавляем краткую информацию
                disk = status.get('disk', {})
                if 'percent' in disk:
                    icon = '🟢' if disk.get('alert') == 'ok' else ('🟡' if disk.get('alert') == 'warning' else '🔴')
                    result_text += f"   Диск: {icon} {disk.get('percent', 0)}%\n"
                
                memory = status.get('memory', {})
                if 'percent' in memory:
                    icon = '🟢' if memory.get('alert') == 'ok' else ('🟡' if memory.get('alert') == 'warning' else '🔴')
                    result_text += f"   Память: {icon} {memory.get('percent', 0)}%\n"
                
                cpu = status.get('cpu', {})
                if 'percent' in cpu:
                    icon = '🟢' if cpu.get('alert') == 'ok' else ('🟡' if cpu.get('alert') == 'warning' else '🔴')
                    result_text += f"   CPU: {icon} {cpu.get('percent', 0)}%\n"
                
                result_text += "\n"
                
            else:
                result_text += f"❌ {server_display}: 🔴 {status.get('error', 'Offline')}\n\n"
        
        # Добавляем проверку локального сервера
        local_status = checker.check_local_server()
        result_text += f"💻 **Локальный сервер (бот)**\n"
        
        if local_status.get('status') == 'online':
            disk = local_status.get('disk', {})
            memory = local_status.get('memory', {})
            cpu = local_status.get('cpu', {})
            
            result_text += f"   Диск: {disk.get('percent', 0)}% ({disk.get('free_gb', 0):.1f} GB свободно)\n"
            result_text += f"   Память: {memory.get('percent', 0)}% ({memory.get('free_gb', 0):.1f} GB свободно)\n"
            result_text += f"   CPU: {cpu.get('percent', 0)}%\n"
        
        # Обновляем сообщение
        await message.edit_text(result_text, parse_mode='Markdown')
        
        logger.info(f"Пользователь {user_id} запросил статус всех серверов")
        
    except Exception as e:
        logger.error(f"Ошибка при проверке всех серверов: {e}")
        await message.edit_text(
            f"❌ {get_text(user_id, 'common', 'error')}: {str(e)}\n\n"
            f"{get_text(user_id, 'status', 'in_development')}"
        )

# ==================== КОМАНДА ВЫБОРА ЯЗЫКА ====================

async def language_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /language"""
    user_id = get_user_id(update)
    
    # Создаем клавиатуру с выбором языка
    keyboard = [
        [InlineKeyboardButton("🇷🇺 Русский", callback_data="lang_ru")],
        [InlineKeyboardButton("🇺🇦 Українська", callback_data="lang_uk")],
        [InlineKeyboardButton("🇬🇧 English", callback_data="lang_en")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    await update.message.reply_text(
        get_text(user_id, 'language', 'select'),
        reply_markup=reply_markup
    )

# ==================== КОМАНДА ВЕРСИИ ====================

async def version_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /version"""
    user_id = get_user_id(update)
    
    try:
        from utils.version import get_detailed_version
        version_info = get_detailed_version()
        
        await update.message.reply_text(
            f"<pre>{version_info}</pre>",
            parse_mode='HTML'
        )
        
        logger.info(f"Пользователь {user_id} запросил информацию о версии")
        
    except Exception as e:
        logger.error(f"Ошибка при получении версии: {e}")
        await update.message.reply_text(
            f"{get_text(user_id, 'common', 'error')}: {get_text(user_id, 'common', 'not_implemented')}"
        )

# ==================== ОБРАБОТЧИК КОЛБЭКОВ ====================

async def callback_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик нажатий на inline кнопки"""
    query = update.callback_query
    await query.answer()
    
    user_id = get_user_id(update)
    callback_data = query.data
    
    if callback_data == "status":
        # Показываем меню выбора сервера для проверки
        keyboard = [
            [
                InlineKeyboardButton("SERV301 🖥", callback_data="check_serv301"),
                InlineKeyboardButton("SERV300 🖥", callback_data="check_serv300")
            ],
            [
                InlineKeyboardButton("Все серверы 🔍", callback_data="check_all"),
                InlineKeyboardButton("Назад ↩", callback_data="back_to_menu")
            ]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        
        await query.edit_message_text(
            "🔍 Выберите сервер для проверки:",
            reply_markup=reply_markup
        )
        
    elif callback_data.startswith("check_"):
        # Обработка проверки конкретного сервера
        server = callback_data.replace("check_", "")
        
        if server == "serv301":
            await query.edit_message_text(f"Проверяю SERV301... ⏳")
            # Создаем фейковый update для вызова команды
            from telegram import Message
            fake_message = Message(
                message_id=query.message.message_id,
                date=query.message.date,
                chat=query.message.chat,
                text="/status301"
            )
            fake_update = Update(update_id=update.update_id, message=fake_message)
            await status301_command(fake_update, context)
            
        elif server == "serv300":
            try:
                from checks.servers import get_server_checker
                from config.settings import SERVERS
                
                await query.edit_message_text("Проверяю SERV300... ⏳")
                
                checker = get_server_checker()
                status = checker.check_remote_server("serv300")
                
                if status.get("status") == "online":
                    disk = status.get("disk", {})
                    memory = status.get("memory", {})
                    cpu = status.get("cpu", {})
                    
                    text = f"✅ *SERV300* (192.168.110.70)\n"
                    text += f"📊 *Статус:* Онлайн\n"
                    text += f"💾 *Диск:* {disk.get('percent', 0)}% ({disk.get('free_gb', 0):.1f} GB свободно)\n"
                    text += f"🧠 *Память:* {memory.get('percent', 0)}% ({memory.get('free_gb', 0):.1f} GB свободно)\n"
                    text += f"⚡ *CPU:* {cpu.get('percent', 0)}%\n"
                    text += f"⏰ *Время работы:* {status.get('uptime', 'N/A')}"
                else:
                    text = f"❌ *SERV300* (192.168.110.70)\n"
                    text += f"📊 *Статус:* Оффлайн\n"
                    text += f"⚠ *Ошибка:* {status.get('error', 'Неизвестная ошибка')}"
                
                await query.edit_message_text(
                    text=text,
                    parse_mode="Markdown"
                )
            except Exception as e:
                await query.edit_message_text(f"❌ Ошибка при проверке SERV300: {str(e)}")        elif server == "all":
            try:
                from checks.servers import get_server_checker
                from config.settings import get_all_servers
                
                await query.edit_message_text("Проверяю все серверы... ⏳")
                
                checker = get_server_checker()
                all_servers = get_all_servers()
                
                results = []
                for server_id in all_servers:
                    status = checker.check_remote_server(server_id)
                    if status.get("status") == "online":
                        results.append(f"✅ {status.get('name', server_id)} - Онлайн")
                    else:
                        results.append(f"❌ {status.get('name', server_id)} - Оффлайн")
                
                text = "📊 *Статус всех серверов:*\n\n"
                text += "\n".join(results)
                text += f"\n\n📈 *Всего серверов:* {len(all_servers)}"
                
                await query.edit_message_text(
                    text=text,
                    parse_mode="Markdown"
                )
            except Exception as e:
                await query.edit_message_text(f"❌ Ошибка при проверке всех серверов: {str(e)}")    elif callback_data == "docker":
        await query.edit_message_text(
            f"🐳 {get_text(user_id, 'menu', 'docker')}...\n"
            f"{get_text(user_id, 'common', 'not_implemented')}"
        )
        
    elif callback_data == "sites":
        await query.edit_message_text(
            f"🌐 {get_text(user_id, 'menu', 'sites')}...\n"
            f"{get_text(user_id, 'common', 'not_implemented')}"
        )
        
    elif callback_data == "help":
        await help_command(update, context)
        
    elif callback_data == "language":
        # Показываем выбор языка
        keyboard = [
            [InlineKeyboardButton("🇷🇺 Русский", callback_data="lang_ru")],
            [InlineKeyboardButton("🇺🇦 Українська", callback_data="lang_uk")],
            [InlineKeyboardButton("🇬🇧 English", callback_data="lang_en")]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        
        await query.edit_message_text(
            get_text(user_id, 'language', 'select'),
            reply_markup=reply_markup
        )
        
    elif callback_data.startswith("lang_"):
        # Изменение языка
        lang_code = callback_data.split("_")[1]
        if lang_code in LANGUAGE_NAMES:
            success = language_manager.set_user_language(user_id, lang_code)
            if success:
                await query.edit_message_text(
                    get_text(user_id, 'language', 'changed', language=get_language_name(lang_code))
                )
                logger.info(f"Пользователь {user_id} сменил язык на {lang_code}")
            else:
                await query.edit_message_text(
                    f"{get_text(user_id, 'common', 'error')}: {get_text(user_id, 'common', 'not_implemented')}"
                )
    
    elif callback_data == "back_to_menu":
        # Возврат в главное меню
        await start_command(update, context)
    
    logger.info(f"Обработан callback: {callback_data} для пользователя {user_id}")

# ==================== РЕГИСТРАЦИЯ ОБРАБОТЧИКОВ ====================

def register_handlers(application):
    """Регистрация всех обработчиков команд"""
    
    # Основные команды
    application.add_handler(CommandHandler("start", start_command))
    application.add_handler(CommandHandler("help", help_command))
    application.add_handler(CommandHandler("menu", menu_command))
    
    # Команды статуса
    application.add_handler(CommandHandler("status301", status301_command))
    application.add_handler(CommandHandler("status300", status300_command))
    application.add_handler(CommandHandler(["status", "check_all"], check_all_command))
    
    # Команда выбора языка
    application.add_handler(CommandHandler("language", language_command))
    
    # Команда версии
    application.add_handler(CommandHandler("version", version_command))
    
    # Обработчик inline кнопок
    application.add_handler(CallbackQueryHandler(callback_handler))
    
    logger.info("Обработчики команд зарегистрированы")
