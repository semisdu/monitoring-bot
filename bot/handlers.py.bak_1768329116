async def check_all_command(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработчик команды /status или /check_all"""
    user_id = get_user_id(update)
    
    try:
        from checks.servers import get_server_checker
        from config.settings import get_all_servers
        
        await send_or_edit_message(update, f"{get_text(user_id, 'status', 'checking_all')} ⏳")
        
        checker = get_server_checker()
        all_servers = get_all_servers()
        
        results = []
        for server_id in all_servers:
            try:
                status = checker.check_remote_server(server_id)
                if status.get("status") == "online":
                    results.append(f"✅ {status.get('name', server_id)} - {get_text(user_id, 'status', 'online')}")
                else:
                    results.append(f"❌ {status.get('name', server_id)} - {get_text(user_id, 'status', 'offline')}")
            except Exception as e:
                results.append(f"⚠️ {server_id} - {get_text(user_id, 'common', 'error')}: {str(e)[:50]}")
        
        text = f"📊 *{get_text(user_id, 'status', 'all_servers_status')}:*\n\n"
        text += "\n".join(results)
        text += f"\n\n📈 *{get_text(user_id, 'status', 'total_servers')}:* {len(all_servers)}"
        
        await send_or_edit_message(update, text)
        
    except Exception as e:
        error_text = f"❌ {get_text(user_id, 'common', 'error')} {get_text(user_id, 'status', 'checking_all_servers')}: {str(e)}"
        logger.error(f"Ошибка в check_all_command: {e}")
        await send_or_edit_message(update, error_text)

