async def check_server_status(update: Update, context: ContextTypes.DEFAULT_TYPE, server_id: str) -> None:
    """Проверка статуса сервера (общая функция)"""
    user_id = get_user_id(update)
    
    try:
        from checks.servers import get_server_checker
        
        # Показываем сообщение о проверке
        checking_text = get_text(user_id, "status", f"checking_{server_id.replace('serv', '')}", default=f"Проверяю {server_id}...")
        await send_or_edit_message(update, f"{checking_text} ⏳")
        
        checker = get_server_checker()
        
        if server_id == "serv301" and update.message and update.message.chat.id == user_id:
            # Локальная проверка для SERV301
            status = checker.check_local_server()
        else:
            # Удаленная проверка
            status = checker.check_remote_server(server_id)
        
        text = format_server_status(status, user_id)
        await send_or_edit_message(update, text)
        
    except Exception as e:
        error_text = f"❌ {get_text(user_id, 'common', 'error')} {get_text(user_id, 'status', 'checking_server')} {server_id}: {str(e)}"
        logger.error(f"Ошибка при проверке {server_id}: {e}")
        await send_or_edit_message(update, error_text)



async def check_server_docker(update: Update, context: ContextTypes.DEFAULT_TYPE, server_id: str) -> None:
    """Проверка Docker контейнеров на сервере"""
    user_id = get_user_id(update)
    
    try:
        from checks.docker import get_docker_monitor
        
        await send_or_edit_message(update, f"{get_text(user_id, 'docker', 'checking_server')} {server_id}... ⏳")
        
        monitor = get_docker_monitor(server_id)
        result = monitor.check_docker_containers()
        
        if result.get("status") == "success":
            containers = result.get("containers", [])
            
            text = f"🐳 *{get_text(user_id, 'docker', 'containers_on')} {server_id}:*\n\n"
            
            for container in containers:
                name = container.get("name", "Unknown")
                status = container.get("status", "Unknown")
                running = container.get("running", False)
                critical = container.get("critical", False)
                
                if not running and critical:
                    text += f"🔴 *{name}:* {status} ({get_text(user_id, 'docker', 'critical')})\n"
                elif not running:
                    text += f"🟡 *{name}:* {status}\n"
                else:
                    text += f"✅ *{name}:* {status}\n"
            
            total = result.get("total_containers", 0)
            running = result.get("running_containers", 0)
            text += f"\n📊 *{get_text(user_id, 'docker', 'summary')}:* {running}/{total} {get_text(user_id, 'docker', 'running')}"
            
        else:
            text = f"❌ {get_text(user_id, 'common', 'error')} {get_text(user_id, 'docker', 'checking_server_docker')} {server_id}: {result.get('error', 'Unknown error')}"
        
        await send_or_edit_message(update, text)
        
    except Exception as e:
        error_text = f"❌ {get_text(user_id, 'common', 'error')} {get_text(user_id, 'docker', 'checking_server_docker')} {server_id}: {str(e)}"
        logger.error(f"Ошибка при проверке Docker на {server_id}: {e}")
        await send_or_edit_message(update, error_text)


